These are general-purpose style fixes used across themes.

*/
[class^="vamtam-theme-"],
[class*=" vamtam-theme-"] {
  /* use !important to prevent issues with browser extensions that change fonts */
  font-family: "theme-icons" !important;
  speak: none;
